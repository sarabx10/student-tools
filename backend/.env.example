# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== Frontend (for CORS) =====
CLIENT_URL=http://localhost:5173

# ===== MySQL Database =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=student_tools

# ===== Auth =====
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ===== AI Provider =====
# You can use OpenAI, Google Gemini, or any compatible API.
# Leave blank while developing; the app falls back to a mock response.
AI_PROVIDER=mock
OPENAI_API_KEY=
GEMINI_API_KEY=
